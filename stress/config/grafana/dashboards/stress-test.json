{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Orders/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(orders_received_total[30s])",
          "legendFormat": "received",
          "refId": "A"
        },
        {
          "expr": "rate(orders_processed_total[30s])",
          "legendFormat": "processed",
          "refId": "B"
        },
        {
          "expr": "rate(orders_failed_total[30s])",
          "legendFormat": "failed",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    },
    {
      "title": "Order Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(order_latency_seconds_bucket[30s]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(order_latency_seconds_bucket[30s]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(order_latency_seconds_bucket[30s]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Backpressure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "orders_queued",
          "legendFormat": "queued",
          "refId": "A"
        },
        {
          "expr": "rate(orders_rate_limited_total[30s])",
          "legendFormat": "rate limited/s",
          "refId": "B"
        },
        {
          "expr": "active_workers",
          "legendFormat": "active workers",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Downstream Service Calls/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(service_calls_total{status=\"success\"}[30s])",
          "legendFormat": "{{ service }} success",
          "refId": "A"
        },
        {
          "expr": "rate(service_calls_total{status=\"failure\"}[30s])",
          "legendFormat": "{{ service }} failure",
          "refId": "B"
        },
        {
          "expr": "rate(service_calls_total{status=\"error\"}[30s])",
          "legendFormat": "{{ service }} error",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    },
    {
      "title": "Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "go_goroutines",
          "legendFormat": "goroutines",
          "refId": "A"
        },
        {
          "expr": "goroutine_count",
          "legendFormat": "app goroutines",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes",
          "legendFormat": "alloc",
          "refId": "A"
        },
        {
          "expr": "go_memstats_sys_bytes",
          "legendFormat": "sys",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      }
    },
    {
      "title": "Success Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(orders_processed_total[1m]) / rate(orders_received_total[1m]) * 100",
          "legendFormat": "success %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["concurx", "stress-test"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "concurx Stress Test",
  "uid": "concurx-stress",
  "version": 1
}
